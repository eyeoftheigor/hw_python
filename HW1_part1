class Chocolate:
    def __init__(self, name: str, price: float):
        if price <= 0:
            raise ValueError("Цена должна быть больше 0")
        self.name = name
        self.price = price

    def discount(self, percent: int) -> float:
        """Возвращает цену со скидкой."""
        return self.price * (1 - percent / 100)


# Демонстрация работы

# создание объектов
