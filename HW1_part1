def count_positive(nums: list[int]) -> int:
    """Возвращает количество чисел больше 0."""
    count = 0
    for num in nums:
        if num > 0:
            count += 1
    return count

def sum_even(nums: list[int]) -> int:
    """Возвращает сумму всех чётных чисел."""
    total = 0
    for num in nums:
        if num % 2 == 0:
            total += num
    return total

def first_divisible(nums: list[int], k: int) -> int | None:
    """
    Возвращает первое число, которое делится на k.
    Если таких чисел нет — возвращает None.
    """
    # Защита от деления на ноль
    if k == 0:
        return None
        
    result = None
    for num in nums:
        if num % k == 0:
            result = num
            break  # Прерываем цикл, как только нашли первое подходящее число
    return result

